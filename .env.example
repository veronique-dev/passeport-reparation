# PostgreSQL
POSTGRES_USER=passeport
POSTGRES_PASSWORD=passeport123

# Vision IA: mock | openai | off
# mock = suggestion locale sans clé (défaut)
# openai = vraie vision (nécessite OPENAI_API_KEY)
# off = pas de suggestion, choix 100% manuel
VISION_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_VISION_MODEL=gpt-4o-mini

# Auth / JWT (min 32 caractères)
JWT_SECRET=passeport-reparation-dev-secret-change-me-32chars-min

# Email (Mailhog en Docker : UI http://localhost:8025)
MAIL_ENABLED=true
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@passeport-reparation.local

# Frontend
APP_FRONTEND_URL=http://localhost:4200
API_BASE_URL=http://localhost:8090
