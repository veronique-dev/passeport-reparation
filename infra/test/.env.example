# Copier vers infra/test/.env et adapter avant le premier déploiement.

# URL publique de l’app (sans slash final) — liens email + URLs média
PUBLIC_BASE_URL=http://TON_IP_OU_DOMAINE

# Port HTTP exposé (80 nécessite root / capabilities ; 8080 plus simple en smoke test)
HTTP_PORT=80

# Mailpit UI (emails de confirm / reset) — à restreindre au firewall si possible
MAILPIT_UI_PORT=8025

# Secrets (obligatoires en test)
POSTGRES_USER=passeport
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-jwt-secret-at-least-32-characters

# CORS (souvent = PUBLIC_BASE_URL ; ajouter d’autres origines séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://TON_IP_OU_DOMAINE

# Email
MAIL_ENABLED=true
MAIL_FROM=noreply@passeport-reparation.test

# Vision
VISION_PROVIDER=mock
OPENAI_API_KEY=
